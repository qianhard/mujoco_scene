<mujoco model="model_test_v1">

    <include file="scene_v1.xml"/>
    <include file="go2.xml"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
  <!-- 1 高度场 -->
    <hfield name="rough_terrain"
          nrow="10" ncol="10" file="rough_10x10.png"
          size="50 50 1.5 0.01"/>
  <!-- 2 纹理 / 材料 -->
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="50 50" reflectance="0.2"/>
    <texture name="grass_tex_" type="2d" file="test_scene_v1/Grass.png" rgb1="1 1 1" />
    <material name="grass_mat_" texture="grass_tex_" texrepeat="1 1" texuniform="true" emission="0.8" specular="0.0" shininess="0.0" />
    <texture name="height_field_tex" type="2d" file="test_scene_v1/ground_grass_3264_4062_Small.png" rgb1="1 1 1" />
    <material name="rough_mat" texture="height_field_tex" texrepeat="10 10" texuniform="true" emission="0.8" specular="0.0" shininess="0.0" />
  </asset>
  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" pos="0 0 -1." size="0 0 0.05" type="plane" material="groundplane"/>
